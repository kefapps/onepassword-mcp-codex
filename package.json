{
  "name": "@jbodin/onepassword-mcp-codex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone MCP server for 1Password desktop app integrations with opaque-by-default secret handling.",
  "license": "MIT",
  "bin": {
    "onepassword-mcp-codex": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test src/**/*.test.ts"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "@1password/sdk": "^0.4.1-beta.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
